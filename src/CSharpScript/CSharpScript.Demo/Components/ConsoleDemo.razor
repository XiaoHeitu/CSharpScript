

<div class="card">
    <h3>Console 控制台</h3>
    <p>使用 Console 类可以在浏览器控制台输出各种类型的日志。</p>

    <div class="demo-section">
        <label>输入日志消息:</label>
        <input @bind="message" placeholder="输入消息..." />
        <button @onclick="LogMessage">Log</button>
        <button class="info" @onclick="InfoMessage">Info</button>
        <button class="warning" @onclick="WarnMessage">Warn</button>
        <button class="danger" @onclick="ErrorMessage">Error</button>
        <button @onclick="DebugMessage">Debug</button>
    </div>

    <div class="demo-section">
        <button @onclick="TestGroup">测试分组</button>
        <button @onclick="TestAssertTrue">Assert (通过)</button>
        <button class="danger" @onclick="TestAssertFalse">Assert (失败)</button>
        <button @onclick="TestCount">Count</button>
        <button @onclick="TestCountReset">Count Reset</button>
        <button @onclick="TestTimer">Timer</button>
    </div>

    <div class="demo-section">
        <button class="danger" @onclick="ClearConsole">Clear</button>
    </div>
</div>

@code {
    private string message = "Hello CSharpScript!";

    private void LogMessage() => BrowserWindow.Instance.Console.Log(message);
    private void InfoMessage() => BrowserWindow.Instance.Console.Info(message);
    private void WarnMessage() => BrowserWindow.Instance.Console.Warn(message);
    private void ErrorMessage() => BrowserWindow.Instance.Console.Error(message);
    private void DebugMessage() => BrowserWindow.Instance.Console.Debug(message);

    private void TestGroup()
    {
        BrowserWindow.Instance.Console.Group("我的分组");
        BrowserWindow.Instance.Console.Log("这是分组内的消息");
        BrowserWindow.Instance.Console.Info("更多信息");
        BrowserWindow.Instance.Console.GroupEnd();
    }

    private void TestAssertTrue() => BrowserWindow.Instance.Console.Assert(true, "这个断言会通过");
    private void TestAssertFalse() => BrowserWindow.Instance.Console.Assert(false, "这个断言会失败");

    private void TestCount()
    {
        BrowserWindow.Instance.Console.Count("点击次数");
    }

    private void TestCountReset() => BrowserWindow.Instance.Console.CountReset("点击次数");

    private void TestTimer()
    {
        BrowserWindow.Instance.Console.Time("耗时操作");
        Thread.Sleep(100);
        BrowserWindow.Instance.Console.TimeEnd("耗时操作");
    }

    private void ClearConsole() => BrowserWindow.Instance.Console.Clear();
}